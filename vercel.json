{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/linktree",
      "destination": "/linktree.html"
    }
  ],
  "redirects": [
    {
      "source": "/book",
      "destination": "https://www.amazon.in/How-Build-Business-Age-AI/dp/8199573775",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
