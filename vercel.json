{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/deon",
      "destination": "/"
    },
    {
      "source": "/deon/api/stats",
      "destination": "/api/stats"
    },
    {
      "source": "/deon/:path*",
      "destination": "/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/book",
      "destination": "https://www.amazon.in/How-Build-Business-Age-AI/dp/8199573775",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "deonmenezes.com"
        }
      ],
      "destination": "https://www.virelity.com/deon",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.deonmenezes.com"
        }
      ],
      "destination": "https://www.virelity.com/deon",
      "permanent": true
    },
    {
      "source": "/deon/:path*",
      "has": [
        {
          "type": "host",
          "value": "deonmenezes.com"
        }
      ],
      "destination": "https://www.virelity.com/deon/:path*",
      "permanent": true
    },
    {
      "source": "/deon/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.deonmenezes.com"
        }
      ],
      "destination": "https://www.virelity.com/deon/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "deonmenezes.com"
        }
      ],
      "destination": "https://www.virelity.com/deon/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.deonmenezes.com"
        }
      ],
      "destination": "https://www.virelity.com/deon/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}